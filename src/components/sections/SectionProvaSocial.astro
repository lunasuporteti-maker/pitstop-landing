---
// Section 4 — Por que PitStop? (substitui prova social enquanto base de clientes cresce)
// Foco em diferenciais concretos em vez de depoimentos ainda não disponíveis.
const diferenciais = [
  {
    icone: '🇧🇷',
    titulo: 'Feito para o Brasil',
    texto: 'Sistema desenvolvido por quem entende de oficinas mecânicas brasileiras. Suporte em português, sem chatbot.',
  },
  {
    icone: '⚡',
    titulo: 'Pronto em minutos',
    texto: 'Cadastro simples, sem instalação, sem configuração técnica. Você começa a usar no mesmo dia.',
  },
  {
    icone: '🔒',
    titulo: 'Seus dados protegidos',
    texto: 'Cada oficina tem seu espaço isolado. Backups automáticos diários. Seus dados são seus.',
  },
];
---

<section class="diferenciais" id="diferenciais">
  <div class="container">
    <h2 class="section-title">Por que escolher o PitStop?</h2>
    <p class="section-lead">
      Um sistema criado para quem vive dentro da oficina — não para quem nunca colocou a mão no motor.
    </p>

    <ul class="diferenciais-grid">
      {
        diferenciais.map((d) => (
          <li class="diferencial-card">
            <span class="diferencial-icone" aria-hidden="true">{d.icone}</span>
            <h3 class="diferencial-titulo">{d.titulo}</h3>
            <p class="diferencial-texto">{d.texto}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .diferenciais {
    background-color: var(--color-bg-alt);
    padding-block: var(--space-lg);
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    text-align: center;
    margin-block: 0 var(--space-sm);
  }

  .section-lead {
    text-align: center;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0 auto var(--space-md);
    font-size: 1.05rem;
  }

  .diferenciais-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .diferencial-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-md);
    text-align: center;
  }

  .diferencial-icone {
    font-size: 2.5rem;
    display: block;
    margin-block-end: var(--space-sm);
  }

  .diferencial-titulo {
    font-size: 1.15rem;
    margin-block: 0 var(--space-xs);
  }

  .diferencial-texto {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .diferenciais-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
