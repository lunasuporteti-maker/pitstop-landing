---
// Section 2 — Problema / dor (PRD 04 §4 Section 2 / Story 5.2 AC3).
// 3 bullets com icones representando dores reais da oficina sem sistema.
const dores = [
  {
    icone: '🔍',
    texto: 'Perde tempo procurando orçamentos antigos no WhatsApp?',
  },
  {
    icone: '📉',
    texto: 'Não sabe quanto realmente lucra em cada serviço?',
  },
  {
    icone: '📵',
    texto: 'Esquece de avisar o cliente sobre o status do veículo?',
  },
];
---

<section class="problema" id="problema">
  <div class="container">
    <h2 class="section-title">Soa familiar?</h2>
    <ul class="problema-list">
      {
        dores.map((dor) => (
          <li class="problema-item">
            <span class="problema-icon" aria-hidden="true">
              {dor.icone}
            </span>
            <p class="problema-text">{dor.texto}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .problema {
    background-color: var(--color-bg-alt);
    padding-block: var(--space-lg);
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    text-align: center;
    margin-block: 0 var(--space-md);
  }

  .problema-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .problema-item {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-md);
    text-align: center;
  }

  .problema-icon {
    font-size: 2.5rem;
    display: block;
    margin-block-end: var(--space-sm);
  }

  .problema-text {
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0;
  }

  @media (min-width: 768px) {
    .problema-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
