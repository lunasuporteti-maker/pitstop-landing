---
// Section 7 — FAQ (PRD 04 §4 Section 7 / Story 5.2 AC8).
// Accordion nativo com <details>/<summary> — acessivel e zero JavaScript.
// Dados de src/data/faq.ts (>= 8 perguntas).
import { faq } from '../../data/faq';
---

<section class="faq" id="faq">
  <div class="container faq-inner">
    <h2 class="section-title">Perguntas frequentes</h2>

    <div class="faq-list">
      {
        faq.map((item) => (
          <details class="faq-item" data-faq-question={item.pergunta}>
            <summary class="faq-question">{item.pergunta}</summary>
            <p class="faq-answer">{item.resposta}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background-color: var(--color-bg);
    padding-block: var(--space-lg);
  }

  .faq-inner {
    max-width: 760px;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    text-align: center;
    margin-block: 0 var(--space-md);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-bg);
  }

  .faq-question {
    cursor: pointer;
    font-weight: 600;
    font-size: 1.05rem;
    padding: var(--space-sm);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
  }

  /* Remove o marcador default e usa um indicador custom. */
  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-primary);
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '\2212'; /* minus sign */
  }

  .faq-answer {
    margin: 0;
    padding: 0 var(--space-sm) var(--space-sm);
    color: var(--color-text-muted);
  }
</style>
