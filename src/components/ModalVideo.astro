---
// Story 5.5 — Modal de vídeo demo com <dialog> nativo.
// Suporta YouTube (iframe) e MP4 direto (<video>).
const rawUrl = import.meta.env.PUBLIC_VIDEO_DEMO_URL as string | undefined;

function toEmbedUrl(url: string | undefined): string {
  if (!url) return '';
  const ytMatch = url.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=|youtube\.com\/shorts\/)([a-zA-Z0-9_-]{11})/);
  if (ytMatch) return `https://www.youtube-nocookie.com/embed/${ytMatch[1]}?rel=0`;
  return url;
}

const embedUrl  = toEmbedUrl(rawUrl);
const hasVideo  = !!embedUrl;
const isMp4     = !!rawUrl && (rawUrl.endsWith('.mp4') || rawUrl.endsWith('.webm'));
---

{hasVideo && (
  <dialog id="modal-video" aria-label="Vídeo de demonstração do PitStop">
    <div class="modal-video-inner">
      <button class="modal-video-close" id="modal-video-close" type="button" aria-label="Fechar vídeo">✕</button>
      <div class="video-wrapper">
        {isMp4 ? (
          <video
            id="video-player"
            src={embedUrl}
            controls
            preload="none"
            style="width:100%;height:100%;border-radius:12px;display:block;"
          >
            Seu navegador não suporta o elemento de vídeo.
          </video>
        ) : (
          <iframe
            id="video-iframe"
            src=""
            data-src={embedUrl}
            title="Demonstração do PitStop"
            frameborder="0"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        )}
      </div>
    </div>
  </dialog>
)}

<script define:vars={{ isMp4 }}>
  const dialog   = document.getElementById('modal-video');
  const closeBtn = document.getElementById('modal-video-close');
  const iframe   = document.getElementById('video-iframe');
  const player   = document.getElementById('video-player');

  if (!dialog) {
    // VIDEO_DEMO_URL não configurado — SectionHero exibe "Ver planos"
  } else {
    function openVideo() {
      if (iframe) iframe.src = iframe.dataset.src ?? '';
      dialog.showModal();
      if (player) player.play().catch(() => {});
    }

    function closeVideo() {
      if (iframe) iframe.src = '';
      if (player) { player.pause(); player.currentTime = 0; }
      dialog.close();
    }

    // Retorna foco ao botão que abriu — WCAG 2.4.3
    dialog.addEventListener('close', () => {
      document.getElementById('btn-ver-demo')?.focus();
    });

    closeBtn?.addEventListener('click', closeVideo);
    dialog.addEventListener('click', (e) => { if (e.target === dialog) closeVideo(); });
    dialog.addEventListener('cancel', closeVideo);
    document.addEventListener('video:open', openVideo);
  }
</script>

<style>
  #modal-video {
    border: none;
    border-radius: 12px;
    padding: 0;
    background: #000;
    max-width: min(880px, 95vw);
    width: 100%;
    box-shadow: 0 8px 48px rgba(0,0,0,.7);
  }

  #modal-video::backdrop {
    background: rgba(0,0,0,.75);
    backdrop-filter: blur(3px);
  }

  .modal-video-inner { position: relative; }

  .modal-video-close {
    position: absolute;
    top: -2.25rem;
    right: 0;
    background: rgba(255,255,255,.15);
    border: none;
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    z-index: 10;
  }

  .modal-video-close:hover { background: rgba(255,255,255,.3); }

  .video-wrapper {
    position: relative;
    padding-top: 56.25%;
  }

  .video-wrapper iframe,
  .video-wrapper video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 12px;
  }
</style>
