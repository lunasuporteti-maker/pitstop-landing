---
import { ctaUrl } from '../utils/utm';

const navLinks = [
  { label: 'Início', href: '/' },
  { label: 'Preços', href: '/precos' },
  { label: 'Contato', href: '/contato' },
];
const cadastroUrl = ctaUrl('header');
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="PitStop — página inicial">
      <svg class="logo-mark" width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="2"/>
        <rect x="15" y="1" width="2" height="4" rx="0.5" fill="currentColor"/>
        <path d="M16 16 L16 5 A 11 11 0 0 1 27 16 Z" fill="#c44800"/>
        <circle cx="16" cy="16" r="2" fill="currentColor"/>
      </svg>
      <span class="logo-wordmark">pit<span class="logo-accent">stop</span></span>
    </a>

    <div class="header-right">
      <nav aria-label="Navegação principal">
        <ul class="nav-list">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <a href={cadastroUrl} class="btn-header-cta">Começar grátis</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo:hover { text-decoration: none; }

  .logo-mark {
    color: var(--color-text);
    flex-shrink: 0;
  }

  .logo-wordmark {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  .logo-accent { color: var(--color-primary); }

  .nav-list {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    color: var(--color-text);
    font-weight: 500;
  }

  .nav-list a:hover { color: var(--color-primary); }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .btn-header-cta {
    background: var(--color-primary);
    color: #fff;
    padding: 0.5rem 1.1rem;
    border-radius: 7px;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .btn-header-cta:hover {
    background: var(--color-primary-dark);
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .nav-list { display: none; }
  }
</style>
