---
// Story 5.4 — Banner de consentimento LGPD.
// Exibido APENAS quando scripts de remarketing estão habilitados (env vars definidas).
// Plausible é cookieless e não exige consentimento — banner não aparece só com Plausible.
const hasRemarketing = !!(
  import.meta.env.PUBLIC_META_PIXEL_ID ||
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID
);
---

{hasRemarketing && (
  <div id="lgpd-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
    <p class="lgpd-text">
      Usamos cookies de marketing para medir e melhorar nossos anúncios.
      Você pode aceitar ou recusar — sem impacto no funcionamento do site.
    </p>
    <div class="lgpd-actions">
      <button id="lgpd-accept" class="lgpd-btn lgpd-btn-accept" type="button">
        Aceitar
      </button>
      <button id="lgpd-reject" class="lgpd-btn lgpd-btn-reject" type="button">
        Recusar
      </button>
    </div>
  </div>
)}

{hasRemarketing && (
  <script is:inline>
    (function () {
      var banner = document.getElementById('lgpd-banner');
      if (!banner) return;

      // Se já decidiu, não mostra o banner
      var saved = localStorage.getItem('lgpd_consent');
      if (saved) { banner.remove(); return; }

      banner.style.display = 'flex';

      document.getElementById('lgpd-accept').addEventListener('click', function () {
        localStorage.setItem('lgpd_consent', 'accepted');
        banner.remove();
        document.dispatchEvent(new CustomEvent('lgpd:accept'));
      });

      document.getElementById('lgpd-reject').addEventListener('click', function () {
        localStorage.setItem('lgpd_consent', 'rejected');
        banner.remove();
      });
    })();
  </script>
)}

<style>
  #lgpd-banner {
    display: none; /* mostrado via JS apenas se sem decisão prévia */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #1a1a2e;
    color: #e2e8f0;
    padding: 1rem 1.5rem;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    border-top: 2px solid #f6c90e;
    font-size: 0.9rem;
  }

  .lgpd-text {
    margin: 0;
    flex: 1;
    min-width: 200px;
  }

  .lgpd-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .lgpd-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    border: 2px solid transparent;
  }

  .lgpd-btn-accept {
    background: #f6c90e;
    color: #000;
    border-color: #f6c90e;
  }

  .lgpd-btn-accept:hover {
    background: #e0b800;
  }

  .lgpd-btn-reject {
    background: transparent;
    color: #e2e8f0;
    border-color: rgba(226, 232, 240, 0.4);
  }

  .lgpd-btn-reject:hover {
    border-color: #e2e8f0;
  }

  @media (max-width: 480px) {
    #lgpd-banner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
