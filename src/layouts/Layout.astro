---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Imagem usada nas tags Open Graph / Twitter (caminho absoluto ou relativo ao site). */
  ogImage?: string;
}

const {
  title = 'PitStop — Sistema de gestao para oficinas',
  description = 'PitStop: o sistema completo para gestao de oficinas mecanicas. Ordens de servico, agendamentos, financeiro e mais.',
  ogImage = '/og-default.png',
} = Astro.props;

// Astro.site vem de astro.config.mjs (https://pitstop.iaqueatende.com.br)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="PitStop" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!--
      LGPD: scripts de remarketing (Meta Pixel / Google Analytics) NAO sao
      carregados aqui. Eles entram na Story 5.4 apenas APOS consentimento
      explicito do usuario (banner de cookies). Ver README secao "Aviso LGPD".
    -->

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
