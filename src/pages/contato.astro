---
// Pagina /contato (PRD 04 / Story 5.3 AC5 / Story 5.5 AC3-AC4).
import Layout from '../layouts/Layout.astro';

const contactEmail   = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'iaqueatende@gmail.com';
const whatsappNumero = import.meta.env.PUBLIC_WHATSAPP_NUMERO ?? '5581995860005';
const whatsappLink   = `https://wa.me/${whatsappNumero}`;
const whatsappDisplay = '(81) 99586-0005';
const webhookUrl     = import.meta.env.PUBLIC_WEBHOOK_CONTATO_URL as string | undefined;
---

<Layout
  title="Contato — PitStop"
  description="Fale com a equipe do PitStop. Tire dúvidas sobre o sistema de gestão para oficinas por e-mail ou WhatsApp, ou envie sua mensagem pelo formulário."
>
  <section class="contato">
    <div class="container contato-grid">
      <div class="contato-intro">
        <h1 class="contato-title">Fale com a gente</h1>
        <p class="contato-lead">
          Tem dúvidas sobre o PitStop ou quer condições para a sua rede de
          oficinas? Use os canais abaixo ou envie uma mensagem.
        </p>

        <ul class="contato-canais">
          <li>
            <strong>E-mail:</strong>
            <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          </li>
          <li>
            <strong>WhatsApp:</strong>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer">
              {whatsappDisplay}
            </a>
          </li>
        </ul>
      </div>

      <form class="contato-form" id="form-contato" aria-label="Formulário de contato" novalidate>
        <label class="form-field">
          <span class="form-label">Nome <span aria-hidden="true">*</span></span>
          <input type="text" name="nome" autocomplete="name" required placeholder="Seu nome" />
        </label>

        <label class="form-field">
          <span class="form-label">E-mail <span aria-hidden="true">*</span></span>
          <input type="email" name="email" autocomplete="email" required placeholder="seu@email.com" />
        </label>

        <label class="form-field">
          <span class="form-label">Mensagem <span aria-hidden="true">*</span></span>
          <textarea name="mensagem" rows="5" required placeholder="Como podemos ajudar?"></textarea>
        </label>

        <div id="form-contato-feedback" role="alert" aria-live="polite"></div>

        <button type="submit" class="btn btn-primary" id="btn-contato-submit">
          Enviar mensagem
        </button>
      </form>
    </div>
  </section>
</Layout>

<script define:vars={{ webhookUrl }}>
  const form = document.getElementById('form-contato');
  const btn  = document.getElementById('btn-contato-submit');
  const fb   = document.getElementById('form-contato-feedback');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;

    btn.disabled = true;
    btn.textContent = 'Enviando…';
    fb.textContent = '';
    fb.className = '';

    const data = Object.fromEntries(new FormData(form).entries());
    data.source = 'landing-contato';

    try {
      if (!webhookUrl) throw new Error('Webhook não configurado');
      const res = await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      fb.textContent = 'Mensagem enviada! Responderemos em breve.';
      fb.className = 'feedback-ok';
      form.reset();
    } catch {
      fb.textContent = 'Erro ao enviar. Use o e-mail ou WhatsApp acima.';
      fb.className = 'feedback-erro';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensagem';
    }
  });
</script>

<style>
  .contato {
    padding-block: var(--space-lg);
  }

  .contato-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .contato-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    margin-block: 0 var(--space-sm);
  }

  .contato-lead {
    color: var(--color-text-muted);
    margin-block: 0 var(--space-md);
  }

  .contato-canais {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contato-canais li {
    padding-block: 0.35rem;
  }

  .contato-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-label {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .contato-form input,
  .contato-form textarea {
    font: inherit;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-bg-alt);
    color: var(--color-text);
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .btn-primary:hover:not(:disabled) { background-color: var(--color-primary-dark); }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

  .feedback-ok  { color: #48bb78; font-size: 0.9rem; }
  .feedback-erro { color: #fc8181; font-size: 0.9rem; }

  @media (min-width: 768px) {
    .contato-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
</style>
