# ============================================================================
# PitStop Landing — Variaveis de ambiente
# ============================================================================
# Copie este arquivo para `.env` e preencha os valores.
# Variaveis com prefixo PUBLIC_ sao expostas no bundle client-side (padrao Astro).
# Variaveis SEM prefixo PUBLIC_ ficam apenas server-side.
# Na Vercel, configure estas variaveis em Settings > Environment Variables.
# ============================================================================

# URL de cadastro do app PitStop (CTA principal)
PUBLIC_CADASTRO_URL=https://app.iaqueatende.com.br/cadastro

# Email de contato exibido no rodape e secao de contato
PUBLIC_CONTACT_EMAIL=iaqueatende@gmail.com
PUBLIC_WHATSAPP_NUMERO=5581998114585

# Dominio configurado no Plausible Analytics (analytics sem cookies, LGPD-friendly)
PUBLIC_PLAUSIBLE_DOMAIN=pitstop.iaqueatende.com.br

# URL do video de demonstracao (Section 5). Deixar em branco esconde a secao.
PUBLIC_VIDEO_DEMO_URL=

# Webhook que recebe os leads do formulario empresarial (Section 9)
PUBLIC_WEBHOOK_EMPRESARIAL_URL=

# Webhook que recebe as mensagens do formulario de contato (Section 9)
PUBLIC_WEBHOOK_CONTATO_URL=

# ----------------------------------------------------------------------------
# REMARKETING / RASTREAMENTO — ATENCAO LGPD
# ----------------------------------------------------------------------------
# LGPD: scripts de remarketing carregam APENAS com consentimento do usuario
# (implementado na Story 5.4 via banner de cookies).
# Deixar em branco para DESABILITAR completamente (recomendado para LGPD
# compliance ate o banner de consentimento estar no ar).
#
# - Quando vazias, NENHUM script de rastreamento e injetado.
# - Quando preenchidas, os scripts so disparam APOS o usuario aceitar
#   cookies de marketing no banner de consentimento.
# ----------------------------------------------------------------------------
PUBLIC_META_PIXEL_ID=
PUBLIC_GA_MEASUREMENT_ID=
